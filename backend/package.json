{
  "name": "connectghin-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "node scripts/run-nest.mjs start --watch",
    "build": "node scripts/run-nest.mjs build",
    "lint": "node scripts/run-eslint.mjs \"src/**/*.ts\"",
    "test:e2e": "node scripts/run-jest.mjs --config ./test/jest-e2e.json --runInBand",
    "prisma:generate": "node scripts/run-prisma.mjs generate",
    "prisma:migrate": "node scripts/run-prisma.mjs migrate dev",
    "prisma:seed": "node scripts/run-prisma.mjs db seed"
  },
  "prisma": {
    "seed": "node scripts/run-ts-node.mjs --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.2",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.2",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.2",
    "@nestjs/platform-socket.io": "^10.4.2",
    "@nestjs/websockets": "^10.4.2",
    "@prisma/client": "^5.20.0",
    "argon2": "^0.40.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "firebase-admin": "^12.6.0",
    "google-auth-library": "^10.6.2",
    "jose": "4.15.9",
    "multer": "^2.1.1",
    "nodemailer": "^6.9.16",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.16.5",
    "@types/nodemailer": "^6.4.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.10.0",
    "jest": "^29.7.0",
    "prisma": "^5.20.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  }
}
