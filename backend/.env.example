DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=connectghin_user
DB_PASSWORD=change-me
DB_DATABASE=connectghin
DATABASE_URL="postgresql://connectghin_user:change-me@localhost:5432/connectghin?schema=public"

# HTTP port (default 3000). Use 3001 when the Next admin app also uses 3000.
# PORT=3001

# Optional comma-separated origins for CORS. If unset, all origins are allowed.
# CORS_ORIGIN="http://localhost:5173,http://127.0.0.1:8080"
# Generate both JWT secrets with: openssl rand -base64 48
JWT_ACCESS_SECRET="change-me-generate-a-long-random-secret"
JWT_REFRESH_SECRET="change-me-generate-another-long-random-secret"
GOOGLE_OAUTH_CLIENT_ID=""
# Android OAuth client ID (optional; also accept idTokens with this audience)
GOOGLE_ANDROID_CLIENT_ID=""
# Web client ID used to verify Google Sign-In idTokens from the mobile app (same audience as Flutter GOOGLE_SERVER_CLIENT_ID / iOS URL scheme).
APPLE_OAUTH_AUDIENCE=""
APP_PUBLIC_URL="http://localhost:5173"
APP_WEB_URL="http://localhost:5173"
# Public API origin for profile photo URLs (no trailing slash). Production: https://api.connectghin.com
API_PUBLIC_BASE_URL="http://localhost:3000"

# Password reset emails (nodemailer). If unset, no email is sent.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="ConnectGHIN <noreply@example.com>"
# Only when SMTP is not configured: return reset token in API response (never in production).
EMAIL_DEV_EXPOSE_RESET_TOKEN="false"

# FCM push (optional). JSON string of Firebase service account (one line).
FIREBASE_SERVICE_ACCOUNT_JSON=""

# Admin UI: fallback display name when AppSettings `admin_brand_name` is unset.
ADMIN_BRAND_NAME=""

# Apple in-app purchase verification
APPLE_IAP_ISSUER_ID=""
APPLE_IAP_KEY_ID=""
APPLE_IAP_BUNDLE_ID=""
# Use one-line PEM with \n escapes.
APPLE_IAP_PRIVATE_KEY=""
APPLE_IAP_ALLOWED_PRODUCT_IDS=""
APPLE_SERVER_NOTIFICATION_SECRET=""

# Google Play in-app purchase verification
GOOGLE_PLAY_PACKAGE_NAME="com.connectghin.app"
# Option A: inline service account JSON (single line)
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=""
# Option B: path to service account JSON file on the server
GOOGLE_PLAY_CREDENTIALS_PATH=""
# Option C: separate email + private key PEM (use one-line PEM with \n escapes)
GOOGLE_PLAY_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_PLAY_SERVICE_ACCOUNT_PRIVATE_KEY=""
GOOGLE_PLAY_ALLOWED_PRODUCT_IDS="connectghin_monthly,connectghin_yearly"
GOOGLE_SERVER_NOTIFICATION_SECRET=""
