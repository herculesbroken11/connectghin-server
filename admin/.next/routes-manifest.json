    },
    {
      "page": "/settings",
      "regex": "^/settings(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/settings(?:/)?$"
    },
    {
      "page": "/subscriptions",
      "regex": "^/subscriptions(?:/)?$",
      "routeKeys": {},
