# Local backend (must match backend PORT; use :3001 when admin dev server uses :3000).
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1

# Production backend:
# NEXT_PUBLIC_API_BASE_URL=https://api.connectghin.com/api/v1

# Optional: deep link for “View public profile” on user detail. Use {{username}} or append path segment after base URL.
# NEXT_PUBLIC_PUBLIC_PROFILE_URL=https://app.example.com/profile/{{username}}
